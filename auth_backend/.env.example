# auth_backend/.env.example
# Copy to auth_backend/.env and fill in ONLY what is listed here.
#
# SECRET_KEY and INTERNAL_SERVICE_TOKEN are NOT stored in this file.
# They are auto-generated at first startup and saved in the auth_app_secrets
# DB table.  To rotate a secret: DELETE the row and restart the service.

# -----------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------
FLASK_ENV=development

# -----------------------------------------------------------------------
# Database  (same PostgreSQL instance as Django is fine)
# Only DB config belongs in env \u2014 everything else is in the DB.
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hotel_db

# -----------------------------------------------------------------------
# Redis  (optional \u2014 falls back to in-memory if not set)
# Used by Flask-Limiter for distributed rate limiting
# -----------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------
# Session / security
# -----------------------------------------------------------------------
MAX_FAILED_LOGINS=5

# Comma-separated origins allowed to make POST/PUT/PATCH/DELETE requests
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourhotel.example.com
